NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info

# MongoDB - OPTIONAL. Leave blank to run entirely in-memory (no persistence).
# Local:  mongodb://localhost:27017/skribbl-clone
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/skribbl-clone
MONGODB_URI=
DB_CONNECT_TIMEOUT_MS=5000

# Game timing (milliseconds)
WORD_CHOICE_TIME_MS=15000
ROUND_INTERMISSION_MS=5000
GAME_OVER_LINGER_MS=10000
EMPTY_ROOM_TTL_MS=60000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
